# MyTradeLedger Environment Configuration
#
# This root .env is read by docker-compose.yml (via ${VAR} substitution) for
# `make up` / `make dev`. Copy this file to .env before starting the stack.

# =============================================================================
# Docker Compose Variables
# =============================================================================

# Postgres credentials — used by the db, server (via DATABASE_URL), and
# pgadmin services. Change these before exposing this beyond localhost.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mytradeledger

# Signs session JWTs — generate a strong random value (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-this-to-a-long-random-secret

# pgAdmin (http://localhost:5050) login.
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# =============================================================================
# Server Environment Variables (when running outside Docker)
# =============================================================================

# Database connection string (required)
# For Docker: postgresql://postgres:postgres@db:5432/mytradeledger?schema=public
# For local:  postgresql://postgres:postgres@localhost:5433/mytradeledger?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/mytradeledger?schema=public"

# Server port (default: 3000)
PORT=3000

# Environment mode (development | production)
NODE_ENV=development

# =============================================================================
# Client Environment Variables (when running outside Docker)
# =============================================================================

# API server URL for the Vite dev server proxy (default: http://localhost:3000)
# For Docker: http://server:3000 (set automatically in docker-compose)
# For local:  http://localhost:3000
VITE_API_URL=http://localhost:3000
