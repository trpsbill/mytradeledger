# Server Configuration
PORT=3000
NODE_ENV=development

# Number of reverse proxies in front of the app (for correct client IP / rate limiting).
# Direct/dev access = 0; production behind Traefik -> nginx = 2.
TRUST_PROXY=0

# Shared store for auth rate limiting. Leave UNSET to use the per-process
# in-memory store (fine for single-instance dev/prod). Set it to a Redis URL to
# make rate-limit counters survive restarts/deploys and be shared across
# instances (required if you ever run more than one server replica).
# REDIS_URL=redis://localhost:6379

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mytradeledger?schema=public"

# Auth — generate a strong random secret for production.
# ⚠ Under Docker Compose, JWT_SECRET is injected from the ROOT .env via
#   `JWT_SECRET: ${JWT_SECRET}` in docker-compose.yml / docker-compose.dev.yml,
#   which overrides this value. Set JWT_SECRET in the root .env, not here.
#   This entry only takes effect when running the server outside Docker.
# e.g.: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Session lifetime controls. SESSION_IDLE_TIMEOUT_MS is the inactivity window
# before a session expires; the client refreshes the token transparently while
# the user is active so they only see the timeout after this long idle.
# SESSION_MAX_LIFETIME_MS is the hard ceiling regardless of activity.
#
# ⚠ Do not set SESSION_IDLE_TIMEOUT_MS below ~4 minutes. The client warning
# modal uses hardcoded 2-minute windows (WARN_BEFORE_EXPIRY_MS and
# ACTIVE_WITHIN_MS in AuthContext.tsx). If the idle timeout is shorter than
# ~4 min, the warn-window check silently refreshes tokens for idle users and
# sessions will outlive the configured timeout.
SESSION_IDLE_TIMEOUT_MS=300000
SESSION_MAX_LIFETIME_MS=28800000

# Signup gate — set to false to block new registrations. Login and all other
# auth flows are unaffected. Re-enabling is a single env-var change + container
# restart (no code rebuild).
SIGNUP_ENABLED=true

# Anti-automation proof-of-work challenge (self-hosted, Altcha-style). Demanded
# only after repeated auth failures on login/register — normal first attempts
# stay friction-free. ON by default; set to false to fully restore the prior
# challenge-free behavior.
CHALLENGE_ENABLED=true
# Difficulty: upper bound for the secret number the client brute-forces. Higher =
# more work per challenge (~maxnumber/2 hashes). 50000 keeps a real user under ~1s.
CHALLENGE_POW_MAX=50000
# How long an issued challenge stays solvable, in milliseconds.
CHALLENGE_POW_EXPIRY_MS=300000
# HMAC key that signs issued challenges so they can be verified statelessly.
# Falls back to JWT_SECRET if unset (under Docker Compose that means the root
# .env value — see the JWT_SECRET note above). Set a dedicated secret in
# production. Must be the same across all instances for a challenge issued by
# one to verify on another.
CHALLENGE_HMAC_SECRET=

# Mailjet (transactional email — used for the support request form only). Set
# MJ_SANDBOX=false to send real email.
MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=
MJ_FROM_EMAIL=noreply@example.com
MJ_FROM_NAME=MyTradeLedger
MJ_SANDBOX=true