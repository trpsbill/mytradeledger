generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  emailVerifiedAt DateTime? @map("email_verified_at") // null = email address not yet verified
  createdAt       DateTime  @default(now()) @map("created_at")

  accounts                 Account[]
  personalAccessTokens     PersonalAccessToken[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]

  @@map("user")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("email_verification_token")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("password_reset_token")
}

model PersonalAccessToken {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  name          String
  tokenHash     String    @unique @map("token_hash")
  tokenPrefix   String    @map("token_prefix")
  lastFourChars String    @map("last_four_chars")
  createdAt     DateTime  @default(now()) @map("created_at")
  lastUsedAt    DateTime? @map("last_used_at")
  expiresAt     DateTime? @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("personal_access_token")
}

// Represents a logical trading account or portfolio
model Account {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  name         String
  baseCurrency String    @default("USD") @map("base_currency")
  isDemo       Boolean   @default(false) @map("is_demo")
  isDefault    Boolean   @default(false) @map("is_default")
  createdAt    DateTime  @default(now()) @map("created_at")
  archivedAt   DateTime? @map("archived_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgerEntries LedgerEntry[]

  @@index([userId])
  @@map("account")
}

// Represents a traded asset or currency (BTC, ETH, USD, USDC, etc.)
model Asset {
  id        String   @id @default(uuid())
  symbol    String   @unique
  name      String?
  precision Int      @default(8)
  createdAt DateTime @default(now()) @map("created_at")

  ledgerEntries          LedgerEntry[] @relation("AssetEntries")
  referenceLedgerEntries LedgerEntry[] @relation("ReferenceAssetEntries")
  feeLedgerEntries       LedgerEntry[] @relation("FeeAssetEntries")

  @@map("asset")
}

// Entry types for ledger entries
enum EntryType {
  BUY
  SELL
  FEE
  DEPOSIT
  WITHDRAWAL
  ADJUSTMENT

  @@map("entry_type")
}

// Core table: each row represents a single financial event
model LedgerEntry {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  timestamp DateTime

  entryType EntryType @map("entry_type")

  symbol   String  // Trading pair symbol (e.g., "BTC/USD", "ETH-USDT")
  quantity Decimal @db.Decimal(24, 12) // Signed: positive = increase, negative = decrease
  price    Decimal @db.Decimal(24, 12) // Price per unit
  fee      Decimal? @db.Decimal(24, 12) // Trading fee amount (optional)

  valueBase Decimal  @db.Decimal(24, 12) @map("value_base") // Total value in base currency (signed, auto-calculated)
  pnl       Decimal? @db.Decimal(24, 12) // Realized P&L for SELL entries (using average cost method)
  netPnl    Decimal? @db.Decimal(24, 12) @map("net_pnl") // Realized net P&L (fee-inclusive cost basis)
  pnlStatus String?  @map("pnl_status") // null = normal; "PNL_UNCOMPUTABLE" = could not be costed

  // Legacy fields - kept for backward compatibility
  assetId          String? @map("asset_id")
  referenceAssetId String? @map("reference_asset_id")
  feeAssetId       String? @map("fee_asset_id")
  externalRef      String? @map("external_ref")
  notes            String?

  createdAt DateTime @default(now()) @map("created_at")

  account        Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  asset          Asset?  @relation("AssetEntries", fields: [assetId], references: [id])
  referenceAsset Asset?  @relation("ReferenceAssetEntries", fields: [referenceAssetId], references: [id])
  feeAsset       Asset?  @relation("FeeAssetEntries", fields: [feeAssetId], references: [id])

  metadata LedgerMetadata[]

  @@index([accountId])
  @@index([timestamp])
  @@index([symbol])
  @@index([entryType])
  @@map("ledger_entry")
}

// Flexible key-value metadata for ledger entries
model LedgerMetadata {
  id            String @id @default(uuid())
  ledgerEntryId String @map("ledger_entry_id")
  key           String
  value         String

  ledgerEntry LedgerEntry @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)

  @@index([ledgerEntryId])
  @@index([key])
  @@map("ledger_metadata")
}
